{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/frankxai/human-mind-intelligence-system/schemas/mind-state.schema.json",
  "title": "MindState",
  "description": "A structured representation of an individual's current cognitive, emotional, behavioral, and social state as inferred by Hermes. NOT a clinical assessment.",
  "type": "object",
  "required": ["schema_version", "session_id", "timestamp", "cognitive", "emotional", "behavioral", "social"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Schema version identifier",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "example": "1.0.0"
    },
    "session_id": {
      "type": "string",
      "description": "Unique identifier for the interaction session",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when this mind-state was inferred"
    },
    "confidence": {
      "type": "number",
      "description": "Overall confidence score for this mind-state inference",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "low_confidence_flag": {
      "type": "boolean",
      "description": "True when overall confidence is below the low_confidence_threshold (0.4)"
    },
    "cognitive": {
      "type": "object",
      "description": "Cognitive style and attention mode signals",
      "$comment": "Enum values for cognitive styles and attention modes are defined in models/cognitive/README.md — that file is the source of truth.",
      "required": ["dominant_style"],
      "properties": {
        "dominant_style": {
          "type": "string",
          "enum": ["analytical", "intuitive", "narrative", "abstract", "concrete"],
          "description": "The most prominent cognitive style observed. Enum source: models/cognitive/README.md"
        },
        "secondary_style": {
          "type": "string",
          "enum": ["analytical", "intuitive", "narrative", "abstract", "concrete"],
          "description": "Secondary cognitive style modifier. Enum source: models/cognitive/README.md"
        },
        "attention_mode": {
          "type": "string",
          "enum": ["focused", "distributed", "sequential", "parallel"],
          "description": "Attention mode. Enum source: models/cognitive/README.md"
        },
        "cognitive_load_signal": {
          "type": "string",
          "enum": ["low", "moderate", "high", "unknown"]
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "References to signals that support this cognitive inference"
        }
      }
    },
    "emotional": {
      "type": "object",
      "description": "Emotional pattern signals (non-clinical)",
      "required": ["dominant_pattern"],
      "properties": {
        "dominant_pattern": {
          "type": "string",
          "enum": ["engaged", "withdrawn", "frustrated", "curious", "confident", "uncertain", "collaborative", "guarded"]
        },
        "secondary_pattern": {
          "type": "string",
          "enum": ["engaged", "withdrawn", "frustrated", "curious", "confident", "uncertain", "collaborative", "guarded"]
        },
        "tone_tendency": {
          "type": "object",
          "properties": {
            "primary": { "type": "string" },
            "secondary": { "type": "string" },
            "variability": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "behavioral": {
      "type": "object",
      "description": "Behavioral tendency signals",
      "required": ["dominant_tendency"],
      "properties": {
        "dominant_tendency": {
          "type": "string",
          "enum": ["proactive", "reactive", "deliberate", "impulsive", "persistent", "adaptive", "habitual", "exploratory"]
        },
        "secondary_tendency": {
          "type": "string",
          "enum": ["proactive", "reactive", "deliberate", "impulsive", "persistent", "adaptive", "habitual", "exploratory"]
        },
        "response_pattern_prediction": {
          "type": "string",
          "description": "Free-text prediction of likely next behavioral response"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "social": {
      "type": "object",
      "description": "Social context and relational pattern signals",
      "required": ["relational_pattern"],
      "properties": {
        "relational_pattern": {
          "type": "string",
          "enum": ["high_trust", "low_trust", "authority_oriented", "peer_oriented", "independent", "interdependent"]
        },
        "communication_style": {
          "type": "object",
          "properties": {
            "directness": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "formality": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "verbosity": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
            "questioning_rate": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
          }
        },
        "tribe_context": {
          "type": "array",
          "description": "Active tribe memberships (from Tribe v2 model)",
          "items": {
            "type": "object",
            "required": ["tribe_id", "role"],
            "properties": {
              "tribe_id": { "type": "string" },
              "label": { "type": "string" },
              "role": { "type": "string" },
              "cohesion_score": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
            }
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "skill_annotations": {
      "type": "array",
      "description": "Annotations from skills invoked during inference",
      "items": {
        "type": "object",
        "required": ["skill_id", "confidence"],
        "properties": {
          "skill_id": {
            "type": "string",
            "enum": ["empathy", "reasoning", "memory"]
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
